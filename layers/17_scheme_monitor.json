   "funds_disbursed": "actual/RE with FY",
   "utilization_pct": "disbursed/allocated where computable",
   "applicants_or_beneficiaries": "latest published count",
   "window": "open|closed|oversubscribed|rolling",
   "arrears": "pending dues to industry where reported",
   "last_verified": "date",
   "sources": [
    "where each figure came from"
   ]
  },
  "refresh_sources": "which update-engine source refreshes this entry (PIB daily / PRS budget-session / portal dashboards / Parliament Questions)"
 },
